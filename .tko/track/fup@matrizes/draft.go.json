            "content": "package main\nimport \"fmt\"\nfunc main() {\n    var l, c int\n    fmt.Scan(&l, &c)\n\n    matriz := make([][]int, l)\n    matrize := make([][]int, l)\n    soma := make ([][]int, l)\n\n    for i:= 0; i < l; i++{\n        matriz[i] = make([]int, c)\n        matrize[i] = make([]int, c)\n        soma[i] = make([]int, c)\n    }\n\n    for i := 0; i < l; i++{\n        for j := 0; j < c; j++{\n            fmt.Scan(&matriz[i][j])\n        }\n    }\n\n    for i := 0; i < l; i++{\n        for j := 0; j < c; j++{\n            fmt.Scan(&matrize[i][j])\n        }\n    }\n\n    for i := 0; i < l; i++{\n        fmt.Print(\"[ \")\n        for j := 0; j < c; j++{\n            soma[i][j] = matriz[i][j] + matrize[i][j]\n            fmt.Print(soma[i][j], \" \")\n        }\n\n        fmt.Print(\"]\")\n        fmt.Println()\n    }\n}\n",
